# Copia este archivo como .env y rellena los valores reales.
# .env NUNCA debe subirse al repositorio (está en .gitignore).

# Backend de almacenamiento para perfiles Kolb: "postgres" (default) o "json"
KOLB_STORAGE_BACKEND=postgres

# Cadena de conexión PostgreSQL de Neon (obligatoria cuando KOLB_STORAGE_BACKEND=postgres)
NEON_DATABASE_URL=postgresql://<usuario>:<password>@<host>/<db>?sslmode=require&channel_binding=require
